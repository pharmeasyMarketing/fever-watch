# Python
__pycache__/
*.py[cod]
.venv/
venv/
env/

# Secrets / env (commit only .env.example)
.env
*.env
!.env.example
serpapi.env
# Google Cloud service-account key for the Sheets API (live lab feed) - NEVER commit
secrets/
*.sa.json
gsheets_sa.json

# Internal docs and spreadsheets (never commit to a public repo)
*.xlsx
*.docx

# Lab-positivity raw counts + full lab city footprint are PROPRIETARY - never commit to the
# public repo (only the derived 0-100 signal in grid.json is public, by design). Keep only the
# counts-free runtime files the city resolver needs (raw -> config_id mapping + manual folds).
data/lab_feed_2025_historic.csv
data/citymap/*
!data/citymap/city_alias_map.csv
!data/citymap/manual_aliases.csv
# Rain-provider benchmark CSVs (internal validation vs IMD gauge truth)
data/benchmark/

# Local data caches (committed data/*.json outputs are explicit and tracked)
data/cache/
# NOAA CPC yearly NetCDF rainfall files (regenerable; downloaded by providers/cpc.py)
data/cpc_cache/

# Historical weather backfill intermediates (regenerable from NASA POWER via
# build_weather.py --start/--end; the compact committed artifact is data/archive/)
data/backfill/

# SSG build output (regenerated by src/build_site.py)
dist/

# Generated per-city share cards (regenerated by src/build_share_cards.py from grid.json)
assets/img/og/
assets/img/share/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
